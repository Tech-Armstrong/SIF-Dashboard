NEXT_PUBLIC_API_BASE=http://localhost:8000

# Show Screener / Build portfolio links in the header after login.
# Set to false on the public production site to keep tools out of the menu.
NEXT_PUBLIC_INTERNAL_TOOLS_ENABLED=true

# Require login before internal tools. Must be true whenever INTERNAL_API_KEY is set below.
NEXT_PUBLIC_INTERNAL_AUTH_ENABLED=true

# Server-side only — must match backend INTERNAL_API_KEY. Powers middleware + login cookie.
# INTERNAL_API_KEY=generate-a-long-random-string
